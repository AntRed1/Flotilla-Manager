# =====================================================================
# mobile-app/.gitignore
# =====================================================================

# Secretos
.env
.env.*
!.env.example

# Node
node_modules/
dist/

# Capacitor — generado automáticamente con `npx cap sync`
# Android build artifacts (NO el código fuente de android/)
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.kotlin/

# iOS — generado por CocoaPods y Xcode
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/*.xcworkspace/xcuserdata/
ios/App/DerivedData/
*.xcuserstate

# PWA icons generados — se regeneran con `npx cap assets generate`
# Comenta estas líneas si quieres versionar los iconos
# icons/

# Vite cache
.vite/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
